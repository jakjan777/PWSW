@model PWSWlab3.ViewModels.NoteListViewModel

<!doctype html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <title>Notatki MVC</title>
    <style>
        body { background: #f3f4f6; color: #1f2937; font-family: Arial, sans-serif; margin: 0; }
        main { background: #fff; border: 1px solid #d1d5db; margin: 32px auto; max-width: 900px; padding: 24px; }
        h1 { margin-top: 0; }
        table { border-collapse: collapse; margin-top: 16px; width: 100%; }
        th, td { border-bottom: 1px solid #d1d5db; padding: 8px; text-align: left; }
        th { background: #f9fafb; }
        form { margin: 0; }
        input { padding: 6px; }
        button, .button { background: #2563eb; border: 1px solid #1d4ed8; color: white; cursor: pointer; padding: 6px 10px; text-decoration: none; }
        a { color: #1d4ed8; }
        .danger { background: #b91c1c; border-color: #991b1b; }
        .message, .status { background: #f9fafb; border: 1px solid #d1d5db; padding: 8px; }
        .toolbar { display: flex; gap: 8px; margin-bottom: 16px; }
    </style>
</head>
<body>
    <main>
        <h1>Notatki</h1>

        @if (TempData["Success"] is string message)
        {
            <p class="message">@message</p>
        }

        <form class="toolbar" method="get" asp-controller="Notes" asp-action="Index">
            <input type="text" name="q" value="@Model.SearchQuery" placeholder="Szukaj notatek..." />
            <button type="submit">Szukaj</button>
            <a class="button" asp-controller="Notes" asp-action="Create">Dodaj notatke</a>
        </form>

        <p>Znaleziono: @Model.TotalCount | Strona: @Model.CurrentPage</p>
        <p class="status">Dekorator: @Model.DecoratorStatus</p>

        <table>
            <thead>
                <tr>
                    <th>Tytul</th>
                    <th>Kategoria</th>
                    <th>Przypieta</th>
                    <th>Wiek</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var note in Model.Notes)
                {
                    <tr>
                        <td>@note.Title</td>
                        <td>@(note.Category ?? "brak")</td>
                        <td>@(note.IsPinned ? "tak" : "nie")</td>
                        <td>@note.AgeLabel</td>
                        <td>
                            <a asp-controller="Notes" asp-action="Edit" asp-route-id="@note.Id">Edytuj</a>
                            <form method="post" asp-controller="Notes" asp-action="Delete" asp-route-id="@note.Id" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button class="danger" type="submit">Usun</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </main>
</body>
</html>
